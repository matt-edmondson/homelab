# Copy this file to terraform.tfvars and customize for your environment
# cp terraform.tfvars.example terraform.tfvars

# Kubernetes Configuration
#kubeconfig_path = "~/.kube/config"

# kube-vip Configuration (DHCP LoadBalancer)
#kube_vip_version   = "v0.6.4"    # kube-vip container version
#kube_vip_interface = "eth0"      # Network interface (usually eth0, ens160, or enp0s3)

# Security Configuration
#baget_api_key           = "your-very-secure-api-key-here-generate-a-random-one"
#grafana_admin_password  = "your-secure-grafana-password"

# Storage Configuration
#longhorn_replica_count     = 2
#baget_storage_size        = "10Gi"
#prometheus_storage_size   = "20Gi"
#grafana_storage_size      = "10Gi"
#alertmanager_storage_size = "5Gi"

# NFS Storage Configuration (Synology NAS)
#nfs_csi_chart_version = "4.11.0"
#nfs_server            = "192.168.0.148"
#nfs_media_share       = "/volume2/media"
#nfs_downloads_share   = "/volume2/downloads"

# CrowdSec Security Engine
#crowdsec_chart_version = "0.22.0"
#crowdsec_bouncer_key   = "generate-with-openssl-rand-hex-32"  # openssl rand -hex 32
#crowdsec_enroll_key    = ""                                    # Optional: from app.crowdsec.net

# OAuth2 Proxy (GitHub SSO)
#oauth_enabled              = true
#oauth2_proxy_chart_version = "10.1.4"
#oauth_github_client_id     = "your-github-oauth-app-client-id"
#oauth_github_client_secret = "your-github-oauth-app-client-secret"
#oauth_cookie_secret        = "generate-with-openssl-rand-base64-32"  # openssl rand -base64 32 | head -c 32
#oauth_github_user          = "your-github-username"

# Resource Configuration
#baget_memory_request = "256Mi"
#baget_memory_limit   = "512Mi"
#baget_cpu_request    = "250m"
#baget_cpu_limit      = "500m"

# Chart Versions (update as needed)
#flannel_version                   = "v0.27.2"           # Flannel container version
#flannel_cni_plugin_version        = "v1.7.1-flannel2"  # CNI plugin binary version
#flannel_network_cidr              = "10.244.0.0/16"    # Pod network CIDR
#longhorn_chart_version            = "1.6.2"
#prometheus_stack_chart_version    = "57.2.0"
#headlamp_chart_version            = "0.40.0"

# Metrics Server (recommended for kubectl top and HPA)
#metrics_server_enabled = true

# Traefik Reverse Proxy Configuration
#traefik_chart_version     = "34.5.0"
#traefik_domain            = "example.com"            # Your domain (services will be at grafana.example.com, etc.)
#traefik_acme_email        = "admin@example.com"      # Let's Encrypt registration email
#traefik_log_level         = "ERROR"
#traefik_acme_storage_size = "1Gi"

# Azure DNS Challenge Credentials (for Let's Encrypt ACME)
#azure_dns_client_id       = "your-azure-app-client-id"
#azure_dns_client_secret   = "your-azure-app-client-secret"
#azure_dns_tenant_id       = "your-azure-tenant-id"
#azure_dns_subscription_id = "your-azure-subscription-id"
#azure_dns_resource_group  = "your-dns-zone-resource-group"
#azure_dns_zone_name       = "example.com"             # Azure DNS zone name (must match traefik_domain)
#external_ip               = "203.0.113.1"             # Your public/external IP (router WAN IP, forwards 80/443 to Traefik)
#dns_ttl                   = 300                        # TTL for DNS A records in seconds

# Traefik Basic Auth (htpasswd format — generate with: htpasswd -nb username password)
#traefik_basic_auth_users  = "admin:$apr1$xyz$hashedpassword"

# Traefik Rate Limiting
#rate_limit_average = 100    # Requests per second
#rate_limit_burst   = 200    # Maximum burst size

# DNS Setup (after deployment):
# 1. Deploy Traefik: make apply-traefik
# 2. Get Traefik IP: kubectl get svc -n traefik traefik -o jsonpath='{.status.loadBalancer.ingress[0].ip}'
# 3. Create a wildcard DNS A record: *.example.com -> <traefik-ip>
#    Or create individual A records for each service subdomain

# Static Sites Configuration
# Each site needs a domain, git repo URL, and branch
#static_sites = [
  # { domain = "example.com", repo_url = "https://github.com/user/site.git", branch = "main" },
#]
#static_sites_git_poll_interval = "60"       # Seconds between git pulls
#static_sites_nginx_image       = "nginx:alpine"
#static_sites_git_image         = "alpine/git:latest"
#static_sites_memory_request    = "64Mi"
#static_sites_memory_limit      = "128Mi"
#static_sites_cpu_request       = "50m"
#static_sites_cpu_limit         = "200m"
# static_sites_git_credentials = "https://user:token@github.com"  # For private repos

# n8n Workflow Automation
#n8n_storage_size   = "5Gi"
#n8n_memory_request = "128Mi"
#n8n_memory_limit   = "512Mi"
#n8n_cpu_request    = "100m"
#n8n_cpu_limit      = "500m"
#n8n_image_tag      = "latest"

# Postfix SMTP Relay (migrated from LXC 102)
#postfix_hostname        = "mail.ktsu.dev"
#postfix_relay_host      = ""                                          # Empty for direct delivery
#postfix_virtual_domains = "ktsu.dev ktsu.io matthewedmondson.com"
#postfix_virtual_aliases = "@ktsu.dev user@gmail.com\n@ktsu.io user@gmail.com"

# Squid Caching Proxy (migrated from LXC 105)
#squid_enabled            = true    # Set to false if not needed
#squid_cache_storage_size = "10Gi"
#squid_max_cache_size_mb  = 8192
#squid_memory_request     = "64Mi"
#squid_memory_limit       = "256Mi"

# Labels
#common_labels = {
#  "managed-by"  = "terraform"
#  "environment" = "homelab"
#  "cluster"     = "main"
#}
