# Copy this file to terraform.tfvars and customize for your environment
# cp terraform.tfvars.example terraform.tfvars

# Kubernetes Configuration
#kubeconfig_path = "~/.kube/config"

# kube-vip Configuration (DHCP LoadBalancer)
#kube_vip_version   = "v0.6.4"    # kube-vip container version
#kube_vip_interface = "eth0"      # Network interface (usually eth0, ens160, or enp0s3)

# Security Configuration
#baget_api_key           = "your-very-secure-api-key-here-generate-a-random-one"
#grafana_admin_password  = "your-secure-grafana-password"

# Storage Configuration
#longhorn_replica_count     = 2
#baget_storage_size        = "10Gi"
#prometheus_storage_size   = "20Gi"
#grafana_storage_size      = "10Gi"
#alertmanager_storage_size = "5Gi"

# NFS Storage Configuration (Synology NAS)
#nfs_csi_chart_version = "4.11.0"
#nfs_server            = "192.168.0.148"
#nfs_media_share       = "/volume2/media"
#nfs_downloads_share   = "/volume2/downloads"

# CrowdSec Security Engine
#crowdsec_enabled       = true    # Set to false to disable CrowdSec
#crowdsec_chart_version = "0.22.0"
#crowdsec_bouncer_key   = "generate-with-openssl-rand-hex-32"  # openssl rand -hex 32
#crowdsec_enroll_key    = ""                                    # Optional: from app.crowdsec.net

# OAuth2 Proxy (GitHub SSO)
#oauth_enabled              = true
#oauth2_proxy_chart_version = "10.1.4"
#oauth_github_client_id     = "your-github-oauth-app-client-id"
#oauth_github_client_secret = "your-github-oauth-app-client-secret"
#oauth_cookie_secret        = "generate-with-openssl-rand-base64-32"  # openssl rand -base64 32 | head -c 32
#oauth_github_user          = "your-github-username"

# BaGet NuGet Server
#baget_enabled        = true    # Set to false to disable BaGet
#baget_memory_request = "256Mi"
#baget_memory_limit   = "512Mi"
#baget_cpu_request    = "250m"
#baget_cpu_limit      = "500m"

# Chart Versions (update as needed)
#flannel_version                   = "v0.27.2"           # Flannel container version
#flannel_cni_plugin_version        = "v1.7.1-flannel2"  # CNI plugin binary version
#flannel_network_cidr              = "10.244.0.0/16"    # Pod network CIDR
#longhorn_chart_version            = "1.6.2"
#monitoring_enabled                = true    # Set to false to disable Prometheus/Grafana/AlertManager
#prometheus_stack_chart_version    = "57.2.0"
#kubernetes_dashboard_enabled      = true    # Set to false to disable Headlamp dashboard
#headlamp_chart_version            = "0.40.0"

# Metrics Server (recommended for kubectl top and HPA)
#metrics_server_enabled = true

# Traefik Reverse Proxy Configuration
#traefik_chart_version     = "34.5.0"
#traefik_domain            = "example.com"            # Your domain (services will be at grafana.example.com, etc.)
#traefik_acme_email        = "admin@example.com"      # Let's Encrypt registration email
#traefik_log_level         = "ERROR"
#traefik_acme_storage_size = "1Gi"

# Azure DNS Challenge Credentials (for Let's Encrypt ACME)
#azure_dns_client_id       = "your-azure-app-client-id"
#azure_dns_client_secret   = "your-azure-app-client-secret"
#azure_dns_tenant_id       = "your-azure-tenant-id"
#azure_dns_subscription_id = "your-azure-subscription-id"
#azure_dns_resource_group  = "your-dns-zone-resource-group"
#azure_dns_zone_name       = "example.com"             # Azure DNS zone name (must match traefik_domain)
#external_ip               = "203.0.113.1"             # Your public/external IP (router WAN IP, forwards 80/443 to Traefik)
#dns_ttl                   = 300                        # TTL for DNS A records in seconds

# Traefik Basic Auth (htpasswd format — generate with: htpasswd -nb username password)
#traefik_basic_auth_users  = "admin:$apr1$xyz$hashedpassword"

# Traefik Rate Limiting
#rate_limit_average = 100    # Requests per second
#rate_limit_burst   = 200    # Maximum burst size

# DNS Setup (after deployment):
# 1. Deploy Traefik: make apply-traefik
# 2. Get Traefik IP: kubectl get svc -n traefik traefik -o jsonpath='{.status.loadBalancer.ingress[0].ip}'
# 3. Create a wildcard DNS A record: *.example.com -> <traefik-ip>
#    Or create individual A records for each service subdomain

# Static Sites Configuration
#static_sites_enabled = true    # Set to false to disable static site hosting
# Each site needs a domain, git repo URL, and branch
#static_sites = [
  # { domain = "example.com", repo_url = "https://github.com/user/site.git", branch = "main" },
#]
#static_sites_git_poll_interval = "60"       # Seconds between git pulls
#static_sites_nginx_image       = "nginx:alpine"
#static_sites_git_image         = "alpine/git:latest"
#static_sites_memory_request    = "64Mi"
#static_sites_memory_limit      = "128Mi"
#static_sites_cpu_request       = "50m"
#static_sites_cpu_limit         = "200m"
# static_sites_git_credentials = "https://user:token@github.com"  # For private repos

# n8n Workflow Automation
#n8n_enabled        = true    # Set to false to disable n8n
#n8n_storage_size   = "5Gi"
#n8n_memory_request = "128Mi"
#n8n_memory_limit   = "512Mi"
#n8n_cpu_request    = "100m"
#n8n_cpu_limit      = "500m"
#n8n_image_tag      = "latest"

# Postfix SMTP Relay (migrated from LXC 102)
#postfix_enabled         = true    # Set to false to disable Postfix
#postfix_hostname        = "mail.ktsu.dev"
#postfix_relay_host      = ""                                          # Empty for direct delivery
#postfix_virtual_domains = "ktsu.dev ktsu.io matthewedmondson.com"
#postfix_virtual_aliases = "@ktsu.dev user@gmail.com\n@ktsu.io user@gmail.com"

# Squid Caching Proxy (migrated from LXC 105)
#squid_enabled            = true    # Set to false if not needed
#squid_cache_storage_size = "10Gi"
#squid_max_cache_size_mb  = 8192
#squid_memory_request     = "64Mi"
#squid_memory_limit       = "256Mi"

# Prowlarr Indexer (migrated from LXC 110)
#prowlarr_enabled        = true    # Set to false to disable Prowlarr
#prowlarr_storage_size   = "2Gi"
#prowlarr_memory_request = "128Mi"
#prowlarr_memory_limit   = "512Mi"
#prowlarr_image_tag      = "latest"

# Sonarr TV Management (migrated from LXC 112)
#sonarr_enabled             = true    # Set to false to disable Sonarr
#sonarr_config_storage_size = "2Gi"
#sonarr_memory_request      = "256Mi"
#sonarr_memory_limit        = "1Gi"
#sonarr_image_tag           = "latest"

# Radarr Movie Management (migrated from LXC 111)
#radarr_enabled             = true    # Set to false to disable Radarr
#radarr_config_storage_size = "2Gi"
#radarr_memory_request      = "256Mi"
#radarr_memory_limit        = "1Gi"
#radarr_image_tag           = "latest"

# qBittorrent + VPN (migrated from VM 113)
#qbittorrent_enabled              = true    # Set to false to disable qBittorrent
#qbittorrent_config_storage_size  = "1Gi"
#qbittorrent_scratch_storage_size = "100Gi"    # Local scratch for active downloads
#qbittorrent_memory_request       = "512Mi"
#qbittorrent_memory_limit         = "2Gi"
#qbittorrent_image_tag            = "latest"
#gluetun_vpn_service_provider     = "private internet access"
#gluetun_vpn_type                 = "wireguard"
#gluetun_wireguard_private_key    = "your-wireguard-private-key"
#gluetun_server_regions           = "AU Melbourne"
# For OpenVPN instead of WireGuard:
#gluetun_vpn_type     = "openvpn"
#gluetun_vpn_username = "your-pia-username"
#gluetun_vpn_password = "your-pia-password"

# Emby Media Server (migrated from LXC 109)
#emby_enabled             = true    # Set to false to disable Emby
#emby_config_storage_size = "10Gi"
#emby_memory_request      = "512Mi"
#emby_memory_limit        = "2Gi"
#emby_image               = "emby/embyserver"    # Override for custom fork
#emby_image_tag           = "latest"
#emby_gpu_enabled         = false    # Set to true for NVENC hardware transcoding
#emby_gpu_min_vram_gb     = 8       # Minimum GPU VRAM in GB (0 = no constraint)

# Bazarr Subtitle Management (Wave 4)
#bazarr_enabled        = true    # Set to false to disable Bazarr
#bazarr_storage_size   = "1Gi"
#bazarr_memory_request = "128Mi"
#bazarr_memory_limit   = "512Mi"
#bazarr_image_tag      = "latest"

# Jackett Indexer Support (Wave 4)
#jackett_enabled        = true    # Set to false to disable Jackett
#jackett_storage_size   = "1Gi"
#jackett_memory_request = "128Mi"
#jackett_memory_limit   = "512Mi"
#jackett_image_tag      = "latest"

# Cleanuparr Library Cleanup (Wave 4)
#cleanuparr_enabled        = true    # Set to false to disable Cleanuparr
#cleanuparr_memory_request = "64Mi"
#cleanuparr_memory_limit   = "256Mi"
#cleanuparr_image_tag      = "latest"

# SABnzbd Usenet Client (Wave 4)
#sabnzbd_enabled        = true    # Set to false to disable SABnzbd
#sabnzbd_storage_size   = "1Gi"
#sabnzbd_memory_request = "256Mi"
#sabnzbd_memory_limit   = "1Gi"
#sabnzbd_image_tag      = "latest"

# Notifiarr Rich Notifications (Wave 4)
#notifiarr_enabled        = true    # Set to false to disable Notifiarr
#notifiarr_storage_size   = "1Gi"
#notifiarr_memory_request = "64Mi"
#notifiarr_memory_limit   = "256Mi"
#notifiarr_image_tag      = "latest"
#notifiarr_config         = ""    # Paste notifiarr.conf contents from LXC 101

# Flaresolverr CAPTCHA Solver (Wave 4 — internal only)
#flaresolverr_enabled        = true    # Set to false to disable Flaresolverr
#flaresolverr_memory_request = "256Mi"
#flaresolverr_memory_limit   = "1Gi"
#flaresolverr_image_tag      = "latest"

# NVIDIA Device Plugin (Wave 5 — enable after GPU nodes are configured)
#nvidia_device_plugin_enabled       = false
#nvidia_device_plugin_chart_version = "0.17.0"

# GPU Node VRAM Map — maps node hostname to VRAM in GB
# Terraform applies cumulative VRAM tier labels (e.g. a 12GB node gets gpu-vram-8gb, gpu-vram-12gb)
# GPU workloads use these labels to find nodes with enough VRAM
#gpu_nodes = {
#  "rainbow.home" = 16
#  "celery.home"  = 12
#}

# Ollama LLM Inference (Wave 5)
#ollama_enabled             = true    # Set to false to disable Ollama
#ollama_config_storage_size = "1Gi"
#ollama_memory_request      = "2Gi"
#ollama_memory_limit        = "8Gi"
#ollama_image_tag           = "latest"
#ollama_gpu_enabled         = false    # Set to true after NVIDIA device plugin is running
#ollama_gpu_min_vram_gb     = 12      # Minimum GPU VRAM in GB (0 = no constraint)

# Qdrant Vector Database (Wave 5)
#qdrant_enabled        = true    # Set to false to disable Qdrant
#qdrant_storage_size   = "4Gi"
#qdrant_memory_request = "256Mi"
#qdrant_memory_limit   = "1Gi"
#qdrant_image_tag      = "latest"

# ChromaDB Vector Database (Wave 5)
#chromadb_enabled        = true    # Set to false to disable ChromaDB
#chromadb_storage_size   = "4Gi"
#chromadb_memory_request = "256Mi"
#chromadb_memory_limit   = "1Gi"
#chromadb_image_tag      = "latest"

# ComfyUI Image Generation (Wave 5)
#comfyui_enabled             = true    # Set to false to disable ComfyUI
#comfyui_config_storage_size = "1Gi"
#comfyui_memory_request      = "2Gi"
#comfyui_memory_limit        = "8Gi"
#comfyui_image_tag           = "latest"
#comfyui_gpu_enabled         = false    # Set to true after NVIDIA device plugin is running
#comfyui_gpu_min_vram_gb     = 16      # Minimum GPU VRAM in GB (0 = no constraint)
#comfyui_hf_token            = ""       # Hugging Face token for downloading gated models

# Homepage Dashboard (Application Portal)
#homepage_enabled        = true     # Set to false to disable Homepage
#homepage_image_tag      = "latest"
#homepage_memory_request = "128Mi"
#homepage_memory_limit   = "256Mi"
#homepage_cpu_request    = "50m"
#homepage_cpu_limit      = "200m"

# Widget API Keys (optional — widgets degrade gracefully without them)
#sonarr_api_key       = ""
#radarr_api_key       = ""
#prowlarr_api_key     = ""
#bazarr_api_key       = ""
#jackett_api_key      = ""
#sabnzbd_api_key      = ""
#qbittorrent_username = ""
#qbittorrent_password = ""
#emby_api_key         = ""
#grafana_username     = "admin"
#grafana_password     = ""

# Labels
#common_labels = {
#  "managed-by"  = "terraform"
#  "environment" = "homelab"
#  "cluster"     = "main"
#}

# ClaudeCluster — Self-Hosted Claude Code Sandbox Platform
#claudecluster_enabled             = true     # Set to false to disable ClaudeCluster
#anthropic_api_key                 = "sk-ant-..."   # Required: Anthropic API key for sandbox agents
#claudecluster_backend_image_tag   = "latest"
#claudecluster_sandbox_image_tag   = "latest"
#claudecluster_agent_image_tag     = "latest"

# GitHub Self-Hosted Runners (ARC — Actions Runner Controller)
# -----------------------------------------------------------------------------
# Setup steps:
#   1. Create a GitHub App under your personal account.
#      - Repository permissions: Actions (read), Administration (read/write), Metadata (read)
#      - Organization permissions: Self-hosted runners (read/write)
#      - Webhook: NOT required (ARC uses long-polling, not webhooks)
#   2. Generate a private key (.pem) and download it.
#   3. Install the App on:
#        - The `ktsu-dev` organization (all repos)
#        - The `matt-edmondson/CardApp` repository
#   4. Find each Installation ID from the install URL:
#        https://github.com/organizations/ktsu-dev/settings/installations/<ID>
#        https://github.com/settings/installations/<ID>
#   5. Populate the four values below. The private key is the full PEM contents
#      (use heredoc syntax: arc_github_app_private_key = <<EOT ... EOT).
# -----------------------------------------------------------------------------
#arc_enabled                             = true     # Set to false to disable ARC
#arc_controller_chart_version            = "0.11.0"
#arc_runner_set_chart_version            = "0.11.0" # Must match controller version
#arc_ktsu_dev_max_runners                = 25       # Peak concurrent runners for ktsu-dev org
#arc_cardapp_max_runners                 = 25       # Peak concurrent runners for CardApp repo
#arc_github_app_id                       = "123456"
#arc_github_app_installation_id_ktsu_dev = "12345678"
#arc_github_app_installation_id_cardapp  = "87654321"
#arc_github_app_private_key              = <<EOT
#-----BEGIN RSA PRIVATE KEY-----
#MIIEpAIBAAKCAQEA...
#-----END RSA PRIVATE KEY-----
#EOT
